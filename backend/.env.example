NODE_ENV=production
PORT=3001

DB_HOST=seu-host-mysql
DB_PORT=3306
DB_USER=seu-usuario
DB_PASSWORD=sua-senha
DB_NAME=cerebrum_db
DB_SSL=true
DB_SSL_STRICT=false

JWT_SECRET=troque-por-um-segredo-forte
JWT_EXPIRES_IN=7d
SESSION_KEY=cerebrum_sid
SESSION_SECRET=troque-por-um-segredo-forte

TRUST_PROXY=true
FORCE_SECURE=true
COOKIE_SAME_SITE=none
COOKIE_DOMAIN=

# Separe por virgula quando tiver mais de uma origem
CORS_ALLOWED=https://seu-frontend.vercel.app
FRONTEND_ORIGIN=https://seu-frontend.vercel.app
SITE_URL=https://seu-frontend.vercel.app

APP_URL=https://seu-frontend.vercel.app
APP_NAME=Cerebrum
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
RESET_PASSWORD_TOKEN_MINUTES=60
EMAILJS_WELCOME_ENABLED=false
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
EMAILJS_RESET_ENABLED=false
EMAILJS_RESET_TEMPLATE_ID=

PY_SERVICE_URL=
WORKER_POLL_MS=15000
