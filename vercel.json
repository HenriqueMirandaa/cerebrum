{
  "framework": "vite",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/minhas", "destination": "/dashboard.html" },
    { "source": "/cronograma", "destination": "/dashboard.html" },
    { "source": "/adicionar", "destination": "/dashboard.html" },
    { "source": "/assistente", "destination": "/dashboard.html" },
    { "source": "/estatisticas", "destination": "/dashboard.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
